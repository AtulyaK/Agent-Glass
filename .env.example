NVIDIA_API_KEY=nvapi-...
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_FAST_MODEL=nvidia/nemotron-mini-4b-instruct
NVIDIA_HEAVY_MODEL=meta/llama-3.1-70b-instruct
NVIDIA_EMBED_MODEL=nvidia/nv-embed-v1

# Database
DATABASE_URL=postgresql://postgres:postgres@db:5432/agent_glass
PGVECTOR=on

# Service Ports (override as needed)
ROUTER_PORT=8001
TRACE_GATEWAY_PORT=8002
CRITIC_PORT=8003
AGENT_PORT=8004
EMBEDDER_PORT=8005
FRONTEND_PORT=3000
EVALUATOR_PORT=8006
SYNTHETIC_GEN_PORT=8007
